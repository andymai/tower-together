{
	"name": "tower-together",
	"version": "0.1.0",
	"private": true,
	"packageManager": "npm@10.9.2",
	"workspaces": [
		"apps/*",
		"packages/*"
	],
	"scripts": {
		"dev": "turbo dev",
		"build": "turbo build",
		"build:wasm": "turbo run build --filter=@tower-together/elevator-core-wasm",
		"typecheck": "turbo typecheck",
		"test": "turbo run test",
		"deploy": "turbo build && turbo deploy"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.4.10",
		"turbo": "^2.3.3"
	}
}
